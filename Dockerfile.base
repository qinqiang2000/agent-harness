# 基础镜像：系统依赖 + Python 包
# 只在 requirements.txt 变更时重新构建：
#   docker build -f Dockerfile.base -t agent-harness-base:latest .
#
# 构建完成后可推送到私有 registry：
#   docker tag agent-harness-base:latest <registry>/agent-harness-base:latest
#   docker push <registry>/agent-harness-base:latest

FROM python:3.11-slim

# 使用国内镜像源加速
RUN sed -i 's|deb.debian.org|mirrors.aliyun.com|g' /etc/apt/sources.list.d/debian.sources 2>/dev/null || \
    sed -i 's|deb.debian.org|mirrors.aliyun.com|g' /etc/apt/sources.list 2>/dev/null

# 安装 SSH 客户端和基础工具
RUN apt-get update && apt-get install -y --no-install-recommends \
    openssh-client \
    sshpass \
    git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/agent-harness

# 安装 Python 依赖（这一步最耗时，固化在基础镜像里）
COPY requirements.txt .
RUN pip install --no-cache-dir \
    -i https://pypi.tuna.tsinghua.edu.cn/simple \
    --extra-index-url https://mirrors.aliyun.com/pypi/simple/ \
    -r requirements.txt

# SSH 密钥目录占位（运行时通过 volume 挂载）
RUN mkdir -p agent_cwd/ssh-keys/aws agent_cwd/ssh-keys/tencent
