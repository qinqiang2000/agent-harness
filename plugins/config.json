{
  "enabled": [
    "yunzhijia",
    "zhichi",
    "audit",
    "open_api",
    "wecom",
    "wecom_group",
    "linear"
  ],
  "plugins": {
    "open_api": {
      "app_id": "${OPEN_API_APP_ID}",
      "app_key": "${OPEN_API_APP_KEY}",
      "session_timeout": 3600,
      "default_skill": "customer-service",
      "async_task_ttl": 3600
    },
    "yunzhijia": {
      "session_timeout": 1800,
      "default_skill": "customer-service",
      "card_template_id": "64d08cb4e4b07ba2b112b395",
      "max_img_per_card": 5,
      "verbose": false
    },
    "zhichi": {
      "session_timeout": 3600,
      "default_skill": "customer-service",
      "token_refresh_buffer_seconds": 300,
      "mock_send": false,
      "transfer_group": "测试技能组",
      "app_id": "${ZHICHI_APP_ID}",
      "app_key": "${ZHICHI_APP_KEY}"
    },
    "audit": {
      "max_upload_size_mb": 20,
      "default_skill": "financial-audit",
      "session_timeout": 3600
    },
    "wecom": {
      "corp_id": "${WECOM_CORP_ID}",
      "corp_secret": "${WECOM_CORP_SECRET}",
      "agent_id": "${WECOM_AGENT_ID}",
      "token": "${WECOM_TOKEN}",
      "encoding_aes_key": "${WECOM_ENCODING_AES_KEY}",
      "session_timeout": 3600,
      "default_skill": "customer-service"
    },
    "wecom_group": {
      "corp_id": "${WECOM_GROUP_CORP_ID}",
      "token": "${WECOM_GROUP_TOKEN}",
      "encoding_aes_key": "${WECOM_GROUP_ENCODING_AES_KEY}",
      "session_timeout": 3600,
      "default_skill": "customer-service"
    },
    "linear": {
      "client_id": "${LINEAR_CLIENT_ID}",
      "client_secret_env": "LINEAR_CLIENT_SECRET",
      "webhook_secret_env": "LINEAR_WEBHOOK_SECRET",
      "redirect_uri_env": "LINEAR_REDIRECT_URI",
      "default_command": "product-workflow",
      "session_timeout": 3600,
      "prd_output_root": "data/linear/prd",
      "token_db_path": "data/linear/linear_tokens.db"
    }
  }
}
