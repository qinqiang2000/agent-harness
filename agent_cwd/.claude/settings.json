{
  "permissions": {
    "allow": [
      "Write(**/data/issue-diagnosis/instincts/**)",
      "Edit(**/data/issue-diagnosis/instincts/**)",
      "Write(**/data/linear/prd/**)",
      "Edit(**/data/linear/prd/**)"
    ],
    "deny": [
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git checkout -b*)",
      "Bash(git branch -d*)",
      "Bash(git branch -D*)",
      "Bash(git reset*)",
      "Bash(git rebase*)",
      "Bash(git merge*)",
      "Bash(git tag*)",
      "Bash(git stash*)",
      "Edit(/tmp/gitlab/**)",
      "Write(/tmp/gitlab/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__elastic__searchTraceOrKeyWordsLog",
        "hooks": [
          {
            "type": "command",
            "command": "../.venv/bin/python3 .claude/hooks/inject-time-range.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "../.venv/bin/python3 .claude/hooks/restrict-edit-write.py"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "elastic": {
      "type": "http",
      "url": "http://jump-test.piaozone.com:9228/mcp"
    },
    "ontology": {
      "type": "http",
      "url": "http://170.106.141.117/ontology-mcp/mcp",
      "headers": {
        "Authorization": "Bearer fpy2026#$"
      }
    }
  }
}
