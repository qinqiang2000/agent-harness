{
  "permissions": {
    "allow": [
      "Write(**/data/issue-diagnosis/instincts/**)",
      "Edit(**/data/issue-diagnosis/instincts/**)"
    ],
    "deny": [
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git checkout -b*)",
      "Bash(git branch -d*)",
      "Bash(git branch -D*)",
      "Bash(git reset*)",
      "Bash(git rebase*)",
      "Bash(git merge*)",
      "Bash(git tag*)",
      "Bash(git stash*)",
      "Edit(/tmp/gitlab/**)",
      "Write(/tmp/gitlab/**)",
      "Bash(ssh * rm *)",
      "Bash(ssh * rm -rf *)",
      "Bash(ssh * kill *)",
      "Bash(ssh * kill -9 *)",
      "Bash(ssh * killall *)",
      "Bash(ssh * reboot*)",
      "Bash(ssh * shutdown*)",
      "Bash(ssh * systemctl stop*)",
      "Bash(ssh * systemctl restart*)",
      "Bash(ssh * systemctl disable*)",
      "Bash(ssh * docker stop*)",
      "Bash(ssh * docker rm*)",
      "Bash(ssh * docker restart*)",
      "Bash(ssh * kubectl delete*)",
      "Bash(ssh * apt *)",
      "Bash(ssh * apt-get *)",
      "Bash(ssh * yum *)",
      "Bash(ssh * dnf *)",
      "Bash(ssh * pip *)",
      "Bash(ssh * chmod *)",
      "Bash(ssh * chown *)",
      "Bash(ssh * mkfs*)",
      "Bash(ssh * dd *)",
      "Bash(ssh * mv *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__elastic__searchTraceOrKeyWordsLog",
        "hooks": [
          {
            "type": "command",
            "command": "../.venv/bin/python3 .claude/hooks/inject-time-range.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "../.venv/bin/python3 .claude/hooks/restrict-ssh.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "../.venv/bin/python3 .claude/hooks/restrict-edit-write.py"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "elastic": {
      "type": "http",
      "url": "http://jump-test.piaozone.com:9228/mcp"
    }
  }
}
