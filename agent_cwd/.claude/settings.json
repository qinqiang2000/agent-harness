{
  "permissions": {
    "allow": [
      "Write(**/data/issue-diagnosis/instincts/**)",
      "Edit(**/data/issue-diagnosis/instincts/**)",
      "Write(/tmp/gitlab/**)",
      "Edit(/tmp/gitlab/**)"
    ],
    "deny": [
      "Bash(git branch -d*)",
      "Bash(git branch -D*)",
      "Bash(git reset*)",
      "Bash(git rebase*)",
      "Bash(git merge*)",
      "Bash(git tag*)",
      "Bash(git stash*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__elastic__searchTraceOrKeyWordsLog",
        "hooks": [
          {
            "type": "command",
            "command": "../.venv/bin/python3 .claude/hooks/auto-parse-elk-result.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__elastic__searchTraceOrKeyWordsLog",
        "hooks": [
          {
            "type": "command",
            "command": "../.venv/bin/python3 .claude/hooks/inject-time-range.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "../.venv/bin/python3 .claude/hooks/restrict-edit-write.py"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "elastic": {
      "type": "http",
      "url": "http://jump-test.piaozone.com:9228/mcp"
    }
  }
}
