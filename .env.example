# ===========================================
# Agent Working Directory
# ===========================================
# Specify the working directory for Agent (default: project root)
# Set to "agent_cwd" to isolate Agent workspace from development files
AGENT_CWD=agent_cwd

# ===========================================
# Default Model Configuration
# ===========================================
# Specify which model configuration to use on startup
# Options:
#   - "claude" (official Claude API)
#   - "claude-router" (local proxy)
#   - "glm" (智谱清言)
#   - "kimi" (Moonshot AI)
#   - "litellm" (LiteLLM proxy)
#   - "minimax" (MiniMax Anthropic 兼容接口)
# If not set, defaults to "glm"
# DEFAULT_MODEL_CONFIG=claude-router
# DEFAULT_MODEL_CONFIG=glm
DEFAULT_MODEL_CONFIG=claude

# ===========================================
# Model Provider Auth Tokens
# ===========================================
# GLM (智谱清言)
GLM_AUTH_TOKEN=a685d38fbc6f46eeb533ab14a5368c5b.***

# Kimi K2.5 (Moonshot AI)
MOONSHOT_API_KEY=your-moonshot-api-key

# Claude Code Router (本地代理)
CLAUDE_ROUTER_AUTH_TOKEN=test

# Claude Official API (官方 API)
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-oJdcm8Ec4PY2T9yVEaaEKwd9gzzRL1jdpLHXs1jWfZ7wiDub-0_BpIiWcduKGb-g3z1bwPwVUbOJlxru_91e7Q--***

# Claude 子 agent 模型（Explore 等使用，默认 Haiku）
# 升级 Haiku 版本时改这里即可，无需改代码
# ANTHROPIC_SMALL_FAST_MODEL=claude-haiku-4-5-20251001

# LiteLLM Proxy (LiteLLM 代理)
LITELLM_API_KEY=your-litellm-api-key
LITELLM_BASE_URL=http://your-litellm-host:4000
# LiteLLM 子 agent 轻量模型（默认 Haiku，proxy 未部署 haiku 时可改为主模型）
# LITELLM_SMALL_FAST_MODEL=claude-haiku-4-5-20251001

# MiniMax (Anthropic 兼容接口)
MINIMAX_API_KEY=your-minimax-api-key
# 国内用户默认: https://api.minimaxi.com/anthropic
# 国际用户使用: https://api.minimax.io/anthropic
# MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic

# ===========================================
# Open API Channel
# ===========================================
OPEN_API_APP_ID=your_app_id
OPEN_API_APP_KEY=your_app_key

# ===========================================
# Proxy Settings (Optional, environment-specific)
# ===========================================

# Proxy for Claude Official API (only set if needed in your environment)
# Uncomment the line below if you need proxy for accessing api.anthropic.com
CLAUDE_PROXY=http://127.0.0.1:7890

# Proxy for claude-router (only set if needed in your environment)
# Uncomment the line below if you need proxy for local development
# CLAUDE_ROUTER_PROXY=http://127.0.0.1:7890

# ===========================================
# Service Port Configuration
# ===========================================
PORT=9090

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=INFO

# Force colored output in log files (optional)
# Options:
#   - "1", "true", "yes", "on": Force enable colors (useful for tail -f)
#   - "0", "false", "no", "off": Force disable colors
#   - Not set or empty: Auto-detect (colors enabled only if output is TTY)
# Default: auto-detect
# FORCE_COLOR=1

# ===========================================
# PostgreSQL Database Configuration (EOP)
# ===========================================
# EOP运营数据库连接信息（用于operational-analytics skill）
POSTGRES_HOST=bj-postgres-68aob3ms.sql.tencentcdb.com
POSTGRES_PORT=22898
POSTGRES_DATABASE=postgres
POSTGRES_USER=agent_eop
POSTGRES_PASSWORD=Fapiaoyun@2026

# 查询超时时间（秒）
POSTGRES_QUERY_TIMEOUT=60

# 允许查询的表（逗号分隔，不含空格）
POSTGRES_ALLOWED_TABLES=t_ocm_kbc_order_settle,t_ocm_order_header,t_ocm_order_lines,t_ocm_tenant

# ===========================================
# 云之家图片卡片配置
# ===========================================
# 卡片消息模板 ID（在云之家后台创建）
YZJ_CARD_TEMPLATE_ID=64d08cb4e4b07ba2b112b395

# 每个卡片最大图片数
YZJ_MAX_IMG_PER_CARD=5

# 服务外网访问地址（云之家需要能访问到）
SERVICE_BASE_URL=http://129.226.88.226:${PORT}

# ===========================================
# 云之家会话超时配置
# ===========================================
# 会话超时时间（单位：秒，默认 1800 = 30 分钟）
# 超过此时间未活动的会话将被自动清理，下次对话将创建新会话
YZJ_SESSION_TIMEOUT=1800

# ===========================================
# 云之家消息详细程度配置
# ===========================================
# 控制返回给云之家的消息详细程度
# true: 详细模式 - 返回所有中间过程和最终答案（默认）
# false: 简洁模式 - 只返回最终答案和 AskUserQuestion，过滤中间思考过程
YZJ_VERBOSE=false

# ===========================================
# 云之家默认 Skill 配置
# ===========================================
# 指定云之家处理器默认使用的 skill
# 可选值: customer-service, operational-analytics 等
# 可通过 URL 参数 ?skill=xxx 动态切换
# 默认值: customer-service
YZJ_DEFAULT_SKILL=customer-service

# ===========================================
# Agent 默认加载的 Skill 列表
# ===========================================
# 请求未指定 skill 时，只加载此列表中的 skill（逗号分隔）
# 不配置则加载所有 skill
# DEFAULT_SKILLS=customer-service,issue-diagnosis

# ===========================================
# Agent 允许使用的 MCP 工具列表
# ===========================================
# 逗号分隔，不配置则不开放任何 MCP 工具
# 基础工具（Skill/Read/Write/Edit/Grep/Glob/Bash/WebFetch/WebSearch/AskUserQuestion）始终开放
# ALLOWED_MCP_TOOLS=mcp__elastic__searchTraceOrKeyWordsLog

# ===========================================
# Diagnosis PostgreSQL（本机 Docker 部署）
# ===========================================
DIAGNOSIS_PG_HOST=127.0.0.1
DIAGNOSIS_PG_PORT=5432
DIAGNOSIS_PG_DATABASE=diagnosis
DIAGNOSIS_PG_USER=agent
DIAGNOSIS_PG_PASSWORD=your-pg-password

# ===========================================
# Apifox 接口文档同步
# ===========================================
# Apifox Personal Access Token（账号设置 → API 访问令牌）
APIFOX_TOKEN=your-apifox-token

# 多项目格式：项目名:项目ID 或 项目名:项目ID:onlineId，多个用逗号分隔
# onlineId 是 published-projects 的 ID，用于同步 doc 类型文档，不填则默认与项目ID相同
# 例如：APIFOX_PROJECTS=发票云:123456,星瀚:789012:abcd-efgh
APIFOX_PROJECTS=项目名:your-project-id

# 同步间隔（分钟，默认 60）
APIFOX_SYNC_INTERVAL_MINUTES=60

# 服务启动时是否立即同步一次（默认 false，按定时间隔同步）
# APIFOX_SYNC_ON_STARTUP=true

# 智齿授权信息
ZHICHI_APP_ID=YOUR_ZHI_CHI_APP_ID
ZHICHI_APP_KEY=YOUR_ZHI_CHI_APP_KEY